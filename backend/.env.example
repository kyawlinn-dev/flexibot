# ──────────────────────────────────────────────
# RSU AI Assistant — Backend environment template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# Optional but recommended: set this as the secret_token in setWebhook to verify requests
TELEGRAM_WEBHOOK_SECRET=your-random-secret-string

# Server
PORT=3000
DEBUG=false

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=asia-southeast1

# Vertex AI RAG
RAG_CORPUS_NAME=projects/YOUR_PROJECT/locations/asia-southeast1/ragCorpora/YOUR_CORPUS_ID
RAG_EMBEDDING_QPM=1000

# Google Cloud Storage
GCS_BUCKET_NAME=your-gcs-bucket-name

# CORS — URL of the admin dashboard (no trailing slash)
ADMIN_DASHBOARD_URL=http://localhost:3001

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

ENABLE_RAG_STATUS_WORKER=true